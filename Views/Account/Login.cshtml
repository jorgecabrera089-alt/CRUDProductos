<h2 class="text-center">🔐 Iniciar sesión</h2>

<form method="post" asp-action="Login" class="w-50 mx-auto mt-4">

    <input type="text" name="username" placeholder="Usuario" class="form-control mb-3" />

    <input type="password" name="password" placeholder="Contraseña" class="form-control mb-3" />

    <button class="btn btn-success w-100">Ingresar</button>

</form>

@if (ViewBag.Error != null)
{
    <p class="text-danger text-center">@ViewBag.Error</p>
}

