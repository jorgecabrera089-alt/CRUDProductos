<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRUDProductos</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Products" asp-action="Index">
                    🏪 SuperMarket
                </a>

                <div class="ms-auto d-flex gap-2">

                    @{
                        var role = Context.Session.GetString("Role");
                        var user = Context.Session.GetString("User");
                    }

                    @if (role == "1")
                    {
                        <a asp-controller="Admin" asp-action="AdminPanel" class="btn btn-warning">
                            ⚙️ Admin
                        </a>
                    }

                    @if (role == "2")
                    {
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-info">
                            📦 Pedidos
                        </a>
                        <a asp-controller="Reports" asp-action="Index" class="btn btn-dark">
                            📊 Reportes
                        </a>
                    }

                    @if (role == "3")
                    {
                        <a asp-controller="Products" asp-action="Index" class="btn btn-light">
                            🛒 Tienda
                        </a>

                        <a asp-controller="Cart" asp-action="Index" class="btn btn-light">
                            🛒 Carrito
                        </a>
                    }

                    @if (user != null)
                    {
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">
                            Logout
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-light">
                            Login
                        </a>
                    }

                </div>

            </div>
        </nav>
    </header>

    <div class="container mt-4">
        @RenderBody()
    </div>

  <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required: false)

</body>
</html>