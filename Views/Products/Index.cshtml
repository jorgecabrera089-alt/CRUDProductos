@model IEnumerable<CRUDProductos.Models.Product>

<h2>Productos</h2>

<a asp-action="Create">Crear nuevo producto</a>

<table border="1">
    <tr>
        <th>Nombre</th>
        <th>Precio</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>
                <a asp-action="Delete" asp-route-id="@item.ProductId">Eliminar</a>
            </td>
        </tr>
    }

</table>