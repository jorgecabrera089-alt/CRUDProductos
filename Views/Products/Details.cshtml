@model CRUDProductos.Models.Product

@{
    ViewData["Title"] = "Detalle del producto";
}

<div class="row mt-4">

    <div class="col-md-6">
        <img src="~/@Model.ImageUrl" class="img-fluid rounded shadow" />
    </div>

    <div class="col-md-6">
        <h2>@Model.Name</h2>

        <h4 class="text-success">$@Model.Price</h4>

        <p class="mt-3">
            @Model.Description
        </p>

        <button onclick="agregarAlCarrito(@Model.ProductId)" class="btn btn-success">
            🛒 Agregar al carrito
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            ⬅ Volver
        </a>
    </div>

</div>

<script>
    function agregarAlCarrito(id) {
        fetch('/Cart/Add/' + id)
            .then(() => alert("Producto agregado al carrito 🛒"));
    }
</script>