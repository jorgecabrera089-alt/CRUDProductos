@model List<CRUDProductos.Models.Product>

<h2>🛒 Carrito</h2>

<table class="table table-dark">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Precio</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>$@item.Price</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-danger btn-sm">
                        ❌
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<h4>Total: $@Model.Sum(p => p.Price)</h4>

<a asp-action="Checkout" class="btn btn-success">Pagar</a>

