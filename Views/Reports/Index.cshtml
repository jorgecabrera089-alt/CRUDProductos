@model List<CRUDProductos.Models.Report>

<h2>📊 Reportes</h2>

<a asp-controller="Reports" asp-action="Create" class="btn btn-success mb-3">
    ➕ Nuevo Reporte
</a>

<div class="alert alert-info">
    <p>💰 Total ventas: $@ViewBag.TotalVentas</p>
    <p>📦 Total pedidos: @ViewBag.TotalPedidos</p>
</div>

@if (Model != null && Model.Count > 0)
{
    <table class="table table-dark">
        <thead>
            <tr>
                <th>Descripción</th>
                <th>Fecha</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Description</td>
                    <td>@item.CreatedAt</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No hay reportes aún</p>
}