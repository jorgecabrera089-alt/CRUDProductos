@{
    ViewData["Title"] = "Admin";
}

<h2 class="text-center mb-4">⚙️ Panel de Administración</h2>

<div class="row">

    <!-- PRODUCTOS -->
    <div class="col-md-3">
        <div class="card p-3 text-center shadow">
            <h5>📦 Productos</h5>
            <a asp-controller="Products" asp-action="Index" class="btn btn-dark mt-2">
                Entrar
            </a>
        </div>
    </div>

    <!-- PROVEEDORES -->
    <div class="col-md-3">
        <div class="card p-3 text-center shadow">
            <h5>🏢 Proveedores</h5>
            <a asp-controller="Suppliers" asp-action="Index" class="btn btn-primary mt-2">
                Entrar
            </a>
        </div>
    </div>

    <!-- DESCUENTOS -->
    <div class="col-md-3">
        <div class="card p-3 text-center shadow">
            <h5>💰 Descuentos</h5>
            <a asp-controller="Discounts" asp-action="Index" class="btn btn-success mt-2">
                Entrar
            </a>
        </div>
    </div>

    <!-- REPORTES -->
    <div class="col-md-3">
        <div class="card p-3 text-center shadow">
            <h5>📊 Reportes</h5>
            <a asp-controller="Reports" asp-action="Index" class="btn btn-danger mt-2">
                Entrar
            </a>
        </div>
    </div>

</div>

<!-- GRÁFICA -->
<div class="mt-5">
    <canvas id="ventasChart" height="100"></canvas>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let ventasChart = null;

        const meses = ["Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"];

        async function cargarVentas() {
            const response = await fetch('/Admin/GetVentas');
            const data = await response.json();

            const labels = data.map(x => meses[x.mes - 1] + " " + x.anio);
            const valores = data.map(x => x.total);

            if (ventasChart) {
                ventasChart.data.labels = labels;
                ventasChart.data.datasets[0].data = valores;
                ventasChart.update();
            } else {
                const ctx = document.getElementById('ventasChart');
                ventasChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Ventas reales',
                            data: valores,
                            backgroundColor: 'rgba(40, 167, 69, 0.6)',
                            borderColor: 'rgba(40, 167, 69, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'top' },
                            title: {
                                display: true,
                                text: 'Ventas por Mes'
                            }
                        }
                    }
                });
            }
        }

        cargarVentas();
        setInterval(cargarVentas, 5000);
    </script>
}